  "home": {
    "hero": {
      "title": "Simple and Easy Online Resume Editor",
      "description": "No registration, no download, just open and write. Data stored locally, export for free.",
      "subtext": "Perfect for those who want to quickly create a clean resume."
    },
    "features": {
      "livePreview": {
        "title": "Live Preview",
        "description": "The page renders in real time based on the selected paper size, so you can edit on the left and preview on the right."
      },
      "localStorage": {
        "title": "Local Storage",
        "description": "Data stored in browser locally, works offline, no privacy concerns."
      },
      "multiFormat": {
        "title": "Multi-format Export",
        "description": "PDF / PNG / JSON / YAML, convenient for job applications, backups, and device switching."
      },
      "paperSize": {
        "title": "Multiple Paper Sizes",
        "description": "Supports A4 / Letter / Legal / A3 with A4 as default for different regions."
      },
      "rawData": {
        "title": "Raw Data Driven",
        "description": "Edit in JSON / YAML directly and import AI-generated resume data quickly."
      },
      "editingFlow": {
        "title": "Smoother Editing Flow",
        "description": "Description fields support multiline input and bullet toggle with preview/export consistency."
      }
    },
    "why": {
      "title": "Why Use Resume Pure",
      "reasons": {
        "pureFocus": "Pure means clear scope: resume editing and export only",
        "noAccount": "No account registration required, ready to use",
        "free": "No paywall, all features are free",
        "professional": "Clean and professional layout, no manual formatting",
        "control": "Control your own data, export and backup anytime"
      }
    }
  },
